-{
-	__mnt_drop_write(file->f_path.mnt);
-}
-
-void mnt_drop_write_file(struct file *file)
-{
-	__mnt_drop_write_file(file);
-	sb_end_write(file_inode(file)->i_sb);
-}
-EXPORT_SYMBOL_NS(mnt_drop_write_file, ANDROID_GKI_VFS_EXPORT_ONLY);
